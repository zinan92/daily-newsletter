{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Executable Task Graph",
  "type": "object",
  "required": ["version", "project", "tasks"],
  "properties": {
    "version": {
      "const": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "type",
          "status",
          "dependencies",
          "success_criteria",
          "test_commands",
          "review_requirements",
          "linter_commands"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z]+-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["contract", "implementation", "workflow", "integration", "verification", "review", "docs"]
          },
          "status": {
            "type": "string",
            "enum": ["todo", "claimed", "in_progress", "blocked", "done"]
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "success_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "test_commands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "review_requirements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "linter_commands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "claimed_by": {
            "type": "string"
          },
          "claimed_at": {
            "type": "string"
          },
          "completed_by": {
            "type": "string"
          },
          "completed_at": {
            "type": "string"
          },
          "commit": {
            "type": "string"
          },
          "history": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

