{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Executable Workflow Diagram Graph",
  "type": "object",
  "required": ["version", "name", "source_of_truth", "nodes", "edges"],
  "properties": {
    "version": {
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "source_of_truth": {
      "const": "workflow/diagram"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "command", "inputs", "outputs"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["trigger", "command", "gate", "artifact", "status", "notification"]
          },
          "command": {
            "type": "string"
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "type"],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["main", "success", "failure", "optional"]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

